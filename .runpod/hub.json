{
  "title": "LTX-Video T2V & I2V",
  "description": "Custom RunPod Serverless worker for Lightricks LTX-Video. Supports pure text-to-video and image-to-video on any 24GB+ GPU. Uses HuggingFace diffusers directly.",
  "type": "serverless",
  "category": "video",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 30,
    "gpuCount": 1,
    "gpuIds": "ADA_24,-NVIDIA H100 PCIe,-NVIDIA H100 80GB HBM3",
    "allowedCudaVersions": ["12.8", "12.7", "12.6", "12.5", "12.4", "12.3", "12.2", "12.1"],
    "presets": [
      {
        "name": "Default",
        "defaults": {
          "MAX_WORKERS": "1",
          "MIN_WORKERS": "0",
          "IDLE_TIMEOUT": "5",
          "FLASHBOOT": "true"
        }
      }
    ],
    "env": [
      {
        "key": "LTX_MODEL_ID",
        "input": {
          "name": "LTX Model ID",
          "type": "string",
          "description": "HuggingFace repo for LTX-Video weights.",
          "default": "Lightricks/LTX-Video",
          "advanced": true
        }
      }
    ]
  }
}
